{
	"name": "deepl",
	"description": "deepl: translate API",
	"icon": "extension",
	"version": "1.0.0",
	"keywords": [
		"directus",
		"directus-extension",
		"directus-extension-endpoint"
	],
	"type": "module",
	"files": [
		"dist"
	],
	"directus:extension": {
		"type": "endpoint",
		"path": "dist/index.js",
		"source": "src/index.ts",
		"host": "^11.15.0"
	},
	"scripts": {
		"build": "pnpm fix && directus-extension build",
		"dev": "directus-extension build -w --no-minify",
		"link": "directus-extension link",
		"validate": "directus-extension validate",
		"l": "pnpm up -i -L",
		"format": "prettier --log-level silent --write \"src/**/*.{js,json,ts}\"",
		"fix": "pnpm i && pnpm dedupe && pnpm format"
	},
	"devDependencies": {
		"@directus/extensions-sdk": "17.1.4",
		"@types/node": "^25.9.1",
		"prettier": "^3.8.3",
		"typescript": "^5.9.3"
	},
	"dependencies": {
		"@exvorn/serbian-transliteration": "^1.0.0"
	},
	"license": "Unlicense",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/tsopany/directus-extension-deepl.git"
	},
	"homepage": "https://github.com/tsopany/directus-extension-deepl#readme",
	"bugs": {
		"url": "https://github.com/tsopany/directus-extension-deepl/issues"
	},
	"packageManager": "pnpm@10.33.0"
}
